{
  "manifest_version": 3,
  "name": "DocuFill – DocuSign Autofill",
  "version": "1.2.1",
  "description": "Autofill DocuSign documents from a CSV/Excel source file using saved field mapping templates.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://*.docusign.com/*", "https://*.docusign.net/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "assets/icon16.png", "48": "assets/icon48.png", "128": "assets/icon128.png" }
  },
  "content_scripts": [{
    "matches": ["https://*.docusign.com/*", "https://*.docusign.net/*"],
    "js": ["content.js"],
    "all_frames": true,
    "run_at": "document_idle"
  }],
  "background": { "service_worker": "background.js" },
  "icons": { "16": "assets/icon16.png", "48": "assets/icon48.png", "128": "assets/icon128.png" },
  "commands": {
    "_execute_action": { "suggested_key": { "default": "Ctrl+Shift+F", "mac": "Command+Shift+F" }, "description": "Open DocuFill popup" }
  }
}
